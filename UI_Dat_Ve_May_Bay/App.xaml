<Application x:Class="UI_Dat_Ve_May_Bay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:UI_Dat_Ve_May_Bay.Converters">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:AdminStatusBrushConverter x:Key="AdminStatusBrushConverter"/>

        <SolidColorBrush x:Key="VnaPrimaryBlue" Color="#00548B"/>
        <SolidColorBrush x:Key="VnaSecondaryTeal" Color="#008291"/>
        <SolidColorBrush x:Key="VnaGold" Color="#D4AF37"/>
        <SolidColorBrush x:Key="VnaLightBlue" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="VnaBorderGray" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="VnaTextDark" Color="#111827"/>
        <SolidColorBrush x:Key="VnaTextGray" Color="#6B7280"/>

        <SolidColorBrush x:Key="SidebarBg" Color="#004675"/>
        <SolidColorBrush x:Key="SidebarActive" Color="#1AFFFFFF"/>
        <DropShadowEffect x:Key="PremiumShadow" BlurRadius="20" ShadowDepth="4" Opacity="0.12" Color="#001A36"/>
        <DropShadowEffect x:Key="GlassShadow" BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>

        <SolidColorBrush x:Key="AdminShellBg" Color="#0B2239"/>
        <SolidColorBrush x:Key="AdminShellSurface" Color="#13395B"/>
        <SolidColorBrush x:Key="AdminShellActive" Color="#1F5E91"/>
        <SolidColorBrush x:Key="AdminShellAccent" Color="#7DD3FC"/>
        <SolidColorBrush x:Key="AdminPageBg" Color="#EEF4FA"/>
        <SolidColorBrush x:Key="AdminCardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AdminCardBorder" Color="#D8E5F2"/>
        <SolidColorBrush x:Key="AdminMutedText" Color="#5B708B"/>
        <SolidColorBrush x:Key="AdminHeadingText" Color="#102A43"/>
        <SolidColorBrush x:Key="AdminInputBg" Color="#F8FBFF"/>
        <SolidColorBrush x:Key="AdminInputBorder" Color="#C8D7E6"/>
        <SolidColorBrush x:Key="AdminPrimary" Color="#0F6CBD"/>
        <SolidColorBrush x:Key="AdminSecondaryBg" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="AdminDanger" Color="#D64545"/>
        <SolidColorBrush x:Key="AdminSuccess" Color="#157347"/>
        <SolidColorBrush x:Key="AdminWarning" Color="#B42318"/>

        <Style x:Key="AdminCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AdminCardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AdminCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="AdminSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AdminHeadingText}"/>
        </Style>

        <Style x:Key="AdminLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AdminMutedText}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="AdminInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Background" Value="{StaticResource AdminInputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AdminInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="AdminInputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource AdminInputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AdminInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="AdminPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="{StaticResource AdminPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="AdminSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminPrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AdminSecondaryBg}"/>
            <Setter Property="Foreground" Value="#0F4C81"/>
        </Style>

        <Style x:Key="AdminDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminPrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AdminDanger}"/>
        </Style>

        <Style x:Key="AdminDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FBFF"/>
            <Setter Property="BorderBrush" Value="#E5EDF5"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5EDF5"/>
            <Setter Property="VerticalGridLinesBrush" Value="#EEF4FA"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="AdminDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F4C81"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderBrush" Value="#0F4C81"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="AdminDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#243B53"/>
        </Style>

        <Style x:Key="AdminDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#243B53"/>
            <Setter Property="BorderBrush" Value="#E6EEF7"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEEFF"/>
                    <Setter Property="Foreground" Value="#102A43"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SideNavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="12,4"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BEE3F8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <ContentPresenter VerticalAlignment="Center"/>
                                <Ellipse x:Name="Indicator" Fill="{StaticResource VnaGold}" Width="6" Height="6" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0EEFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VnaPrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="{StaticResource VnaPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Application.Resources>
</Application>
