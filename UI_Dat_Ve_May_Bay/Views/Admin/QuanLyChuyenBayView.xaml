<UserControl x:Class="UI_Dat_Ve_May_Bay.Views.Admin.QuanLyChuyenBayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource AdminPageBg}">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource AdminCardStyle}"/>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource AdminSectionTitleStyle}"/>
        <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource AdminLabelStyle}"/>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AdminInputTextBoxStyle}"/>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminPrimaryButtonStyle}"/>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminSecondaryButtonStyle}"/>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminDangerButtonStyle}"/>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,14" Padding="20" CornerRadius="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#123B63" Offset="0"/>
                    <GradientStop Color="#1B6497" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,18,0">
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="White" Text="Quản lý chuyến bay"/>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D9EAF7"
                               Text="Lọc tuyến, xem chi tiết, cập nhật nhanh và xoá chuyến bay ngay trong khu quản trị."
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1" Padding="14" Background="#26FFFFFF" CornerRadius="16" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Foreground="#D9EAF7" FontSize="11" Text="Tổng tuyến bay"/>
                        <TextBlock Margin="0,6,0,0" Foreground="White" FontSize="24" FontWeight="Bold" Text="{Binding TongSoChuyenBay}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,14" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" Text="Bộ lọc chuyến bay"/>
                    <Border Grid.Column="1" Padding="12,8" Background="#F2F7FC" CornerRadius="14" VerticalAlignment="Center">
                        <TextBlock Foreground="#1F3A56" FontWeight="SemiBold" Text="{Binding FilterBadgeText}"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Sân bay đi"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding MaSanBayDi, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Sân bay đến"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding MaSanBayDen, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Hãng bay"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding TenHangBay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Giá min"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding GiaMin, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Giá max"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding GiaMax, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Grid Grid.Column="5" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ResetBoLocCommand}"
                                Content="Đặt lại"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding LoadDanhSachCommand}"
                                Content="Tìm tuyến"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Danh sách chuyến bay"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource AdminMutedText}"
                                       Text="Chọn chuyến để xem lịch bay hôm nay, tiện nghi và mở trình chỉnh sửa riêng."/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Width="168"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding OpenEditorCommand}"
                                Content="Mở trình chỉnh sửa"/>
                    </DockPanel>

                    <Border Grid.Row="1" Background="#F8FBFF" BorderBrush="#E3EDF7" BorderThickness="1" CornerRadius="14">
                        <Grid>
                            <DataGrid x:Name="ChuyenBayDataGrid"
                                      Style="{StaticResource AdminDataGridStyle}"
                                      ItemsSource="{Binding DanhSachChuyenBay}"
                                      SelectedItem="{Binding SelectedChuyenBay, Mode=TwoWay}"
                                      IsReadOnly="True"
                                      ColumnHeaderStyle="{StaticResource AdminDataGridHeaderStyle}"
                                      CellStyle="{StaticResource AdminDataGridCellStyle}"
                                      RowStyle="{StaticResource AdminDataGridRowStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                                    <DataGridTextColumn Header="Hãng bay" Binding="{Binding TenHangBay}" Width="140"/>
                                    <DataGridTextColumn Header="Hành trình" Binding="{Binding HanhTrinhText}" Width="*"/>
                                    <DataGridTextColumn Header="Giá" Binding="{Binding GiaText}" Width="150"/>
                                    <DataGridTextColumn Header="Lịch" Binding="{Binding SoLichBay}" Width="80"/>
                                    <DataGridTextColumn Header="Ghế" Binding="{Binding SoGheNgoi}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="#F8FBFF"
                                    Visibility="{Binding ElementName=ChuyenBayDataGrid, Path=HasItems, Converter={StaticResource InverseBoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="42"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#9FB3C8"
                                               HorizontalAlignment="Center"
                                               Text="&#xE804;"/>
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AdminHeadingText}"
                                               HorizontalAlignment="Center"
                                               Text="Chưa có chuyến bay phù hợp"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Thao tác nhanh"/>
                        <UniformGrid Columns="2" Margin="0,12,0,0">
                            <Button Margin="0,0,10,10"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenEditorCommand}"
                                    Content="Mở drawer chỉnh sửa"/>
                            <Button Margin="0,0,0,10"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ResetFormCommand}"
                                    Content="Tạo chuyến mới"/>
                            <Button Margin="0,0,10,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding XemChiTietCommand}"
                                    Content="Tải lại chi tiết"/>
                            <Button Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding XoaChuyenBayCommand}"
                                    Content="Xóa chuyến bay"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Chi tiết và lịch bay hôm nay"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Sân bay đi"/>
                                <TextBlock Foreground="#102A43"
                                           FontWeight="SemiBold"
                                           Text="{Binding ChiTietChuyenBay.SanBayDi.Ten, TargetNullValue=--}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#486581"
                                           Text="{Binding ChiTietChuyenBay.SanBayDi.ViTriText, TargetNullValue=--}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Sân bay đến"/>
                                <TextBlock Foreground="#102A43"
                                           FontWeight="SemiBold"
                                           Text="{Binding ChiTietChuyenBay.SanBayDen.Ten, TargetNullValue=--}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#486581"
                                           Text="{Binding ChiTietChuyenBay.SanBayDen.ViTriText, TargetNullValue=--}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Background="#F8FBFF" BorderBrush="#E3EDF7" BorderThickness="1" CornerRadius="14">
                            <Grid>
                                <DataGrid x:Name="LichBayDataGrid"
                                          Style="{StaticResource AdminDataGridStyle}"
                                          ItemsSource="{Binding LichBayHomNay}"
                                          IsReadOnly="True"
                                          ColumnHeaderStyle="{StaticResource AdminDataGridHeaderStyle}"
                                          CellStyle="{StaticResource AdminDataGridCellStyle}"
                                          RowStyle="{StaticResource AdminDataGridRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Lịch" Binding="{Binding Id}" Width="80"/>
                                        <DataGridTextColumn Header="Khởi hành" Binding="{Binding ThoiGianDiText}" Width="150"/>
                                        <DataGridTextColumn Header="Hạ cánh" Binding="{Binding ThoiGianDenText}" Width="150"/>
                                        <DataGridTextColumn Header="Thời gian bay" Binding="{Binding ThoiGianBayText}" Width="120"/>
                                        <DataGridTextColumn Header="Giá" Binding="{Binding GiaText}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Background="#F8FBFF"
                                        Visibility="{Binding ElementName=LichBayDataGrid, Path=HasItems, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontSize="34"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="#9FB3C8"
                                                   HorizontalAlignment="Center"
                                                   Text="&#xE787;"/>
                                        <TextBlock Margin="0,10,0,0"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AdminHeadingText}"
                                                   HorizontalAlignment="Center"
                                                   Text="Chưa có lịch bay hôm nay"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <ItemsControl Grid.Row="3" Margin="0,12,0,0" ItemsSource="{Binding TienNghi}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,10,10" Padding="12,8" Background="#EFF6FF" CornerRadius="14">
                                        <TextBlock Foreground="#0F4C81" FontWeight="SemiBold" Text="{Binding TenTienNghi}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Background="#BBD7EBF7"
                    CornerRadius="18"
                    Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Border Width="460"
                            HorizontalAlignment="Right"
                            Margin="18"
                            Padding="20"
                            Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#102A43" Text="Chỉnh sửa chuyến bay"/>
                                    <TextBlock Margin="0,4,0,0" Foreground="#5B708B" Text="Form tách riêng để phần lịch bay và chi tiết luôn rõ ràng."/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Width="42"
                                        Height="42"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding CloseEditorCommand}"
                                        Content="✕"/>
                            </DockPanel>

                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="ID chuyến bay"/>
                                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding FormIdChuyenBay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="ID hãng bay"/>
                                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding FormIdHangBay}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Mã sân bay đi"/>
                                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding FormMaSanBayDi}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Mã sân bay đến"/>
                                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding FormMaSanBayDen}"/>
                                </StackPanel>
                            </Grid>

                            <UniformGrid Grid.Row="2" Columns="3" Margin="0,20,0,0">
                                <Button Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseEditorCommand}" Content="Đóng"/>
                                <Button Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ResetFormCommand}" Content="Làm mới"/>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding LuuChuyenBayCommand}" Content="Lưu chuyến bay"/>
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
