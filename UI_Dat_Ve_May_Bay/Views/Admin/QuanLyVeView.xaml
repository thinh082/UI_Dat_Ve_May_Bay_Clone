<UserControl x:Class="UI_Dat_Ve_May_Bay.Views.Admin.QuanLyVeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource AdminPageBg}">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource AdminCardStyle}"/>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource AdminSectionTitleStyle}"/>
        <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource AdminLabelStyle}"/>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AdminInputTextBoxStyle}"/>
        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource AdminInputComboBoxStyle}"/>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminPrimaryButtonStyle}"/>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminSecondaryButtonStyle}"/>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminDangerButtonStyle}"/>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,14" Padding="20" CornerRadius="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#123B63" Offset="0"/>
                    <GradientStop Color="#1B6497" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.6*"/>
                    <ColumnDefinition Width="0.95*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="White" Text="Quản lý vé"/>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="#D9EAF7"
                               Text="Tra cứu vé, xem chi tiết, cập nhật trạng thái và in PDF trên cùng một không gian quản trị."
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1" Margin="0,0,12,0" Padding="14" Background="#26FFFFFF" CornerRadius="16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Foreground="#D9EAF7" FontSize="11" Text="Tổng vé đang hiển thị"/>
                        <TextBlock Margin="0,6,0,0" Foreground="White" FontSize="26" FontWeight="Bold" Text="{Binding TongSoVe}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="14" Background="#26FFFFFF" CornerRadius="16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Foreground="#D9EAF7" FontSize="11" Text="Vé đang chọn"/>
                        <TextBlock Margin="0,6,0,0" Foreground="White" FontSize="18" FontWeight="Bold" Text="{Binding SelectedTicketLabel}"/>
                        <TextBlock Margin="0,4,0,0" Foreground="#D9EAF7" Text="{Binding SelectedHanhTrinhText}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,14" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" Text="Bộ lọc tìm kiếm"/>
                    <Border Grid.Column="1"
                            Padding="12,8"
                            Background="#FFF1F1"
                            CornerRadius="14"
                            VerticalAlignment="Center"
                            Visibility="{Binding FilterBadgeVisibility}">
                        <TextBlock Foreground="#B42318" FontWeight="SemiBold" Text="{Binding FilterBadgeText}"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Mã vé"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding MaDatVe, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Email hành khách"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Số điện thoại"/>
                        <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Trạng thái"/>
                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                  ItemsSource="{Binding TrangThaiOptions}"
                                  SelectedItem="{Binding TrangThai, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Từ ngày đặt"/>
                        <DatePicker Padding="8"
                                    Background="{StaticResource AdminInputBg}"
                                    BorderBrush="{StaticResource AdminInputBorder}"
                                    BorderThickness="1"
                                    SelectedDate="{Binding NgayDatFrom}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Đến ngày đặt"/>
                        <DatePicker Padding="8"
                                    Background="{StaticResource AdminInputBg}"
                                    BorderBrush="{StaticResource AdminInputBorder}"
                                    BorderThickness="1"
                                    SelectedDate="{Binding NgayDatTo}"/>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Margin="0,18,12,0"
                            Padding="12,8"
                            Background="#FFF8E8"
                            CornerRadius="14"
                            VerticalAlignment="Bottom"
                            Visibility="{Binding InlineFeedbackVisibility}">
                        <TextBlock Foreground="#B26A00"
                                   FontWeight="SemiBold"
                                   Text="{Binding InlineFeedbackText}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Grid Grid.Column="3" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ResetBoLocCommand}"
                                Content="Xóa lọc"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding LoadDanhSachCommand}"
                                Content="Tìm vé"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.85*"/>
                <ColumnDefinition Width="1.05*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Danh sách vé"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource AdminMutedText}"
                                       Text="Danh sách được tối ưu để thao tác nhanh, nhìn rõ trạng thái và chi tiết vé theo thời gian thực."/>
                        </StackPanel>
                        <Border Grid.Column="1" Padding="12,8" Background="#F2F7FC" CornerRadius="14" VerticalAlignment="Center">
                            <TextBlock Foreground="#1F3A56"
                                       FontWeight="SemiBold"
                                       Text="{Binding TongSoVe, StringFormat=Tổng cộng: {0} vé}"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Background="#F8FBFF" BorderBrush="#E3EDF7" BorderThickness="1" CornerRadius="14">
                        <Grid>
                            <DataGrid x:Name="VeDataGrid"
                                      Style="{StaticResource AdminDataGridStyle}"
                                      ItemsSource="{Binding DanhSachDatVe}"
                                      SelectedItem="{Binding SelectedDatVe, Mode=TwoWay}"
                                      IsReadOnly="True"
                                      ColumnHeaderStyle="{StaticResource AdminDataGridHeaderStyle}"
                                      CellStyle="{StaticResource AdminDataGridCellStyle}"
                                      RowStyle="{StaticResource AdminDataGridRowStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã vé" Binding="{Binding Id}" Width="80"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                                    <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai}" Width="130"/>
                                    <DataGridTemplateColumn Header="Trạng thái" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                            <TextBlock HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding TrangThai, Converter={StaticResource AdminStatusBrushConverter}, ConverterParameter=foreground}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding TrangThai}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Ngày đặt" Binding="{Binding NgayDatText}" Width="145"/>
                                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding GiaText}" Width="130"/>
                                    <DataGridTextColumn Header="Hành trình" Binding="{Binding HanhTrinhText}" Width="190"/>
                                    <DataGridTextColumn Header="Ghế" Binding="{Binding SoGhe}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="#F8FBFF"
                                    Visibility="{Binding ElementName=VeDataGrid, Path=HasItems, Converter={StaticResource InverseBoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="42"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#9FB3C8"
                                               HorizontalAlignment="Center"
                                               Text="&#xE14C;"/>
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AdminHeadingText}"
                                               HorizontalAlignment="Center"
                                               Text="Chưa có vé phù hợp"/>
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource AdminMutedText}"
                                               HorizontalAlignment="Center"
                                               Text="Hãy thử nới điều kiện lọc hoặc tải lại dữ liệu."
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Padding="14,8" Background="#EAF2FF" CornerRadius="14" VerticalAlignment="Center">
                            <TextBlock Foreground="#0F6CBD"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Text="{Binding SelectedTicketLabel}"/>
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="16,0,18,0"
                                   VerticalAlignment="Center"
                                   Foreground="#334E68"
                                   Text="{Binding SelectedKhachHangText}"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Column="2" Margin="0,0,18,0" VerticalAlignment="Center">
                            <TextBlock Foreground="#486581" FontSize="10" Text="Sân bay đi"/>
                            <TextBlock Foreground="#102A43" FontWeight="SemiBold" Text="{Binding SelectedSanBayDiText}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,18,0" VerticalAlignment="Center">
                            <TextBlock Foreground="#486581" FontSize="10" Text="Sân bay đến"/>
                            <TextBlock Foreground="#102A43" FontWeight="SemiBold" Text="{Binding SelectedSanBayDenText}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Border Grid.Column="4"
                                Padding="12,8"
                                Background="{Binding SelectedStatusBackground}"
                                CornerRadius="14"
                                VerticalAlignment="Center">
                            <TextBlock Foreground="{Binding SelectedStatusForeground}"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedTrangThaiText}"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Thông tin chi tiết"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Email"/>
                                <TextBlock Foreground="#102A43" FontWeight="SemiBold" Text="{Binding ChiTietDatVe.Email, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Số điện thoại"/>
                                <TextBlock Foreground="#102A43" FontWeight="SemiBold" Text="{Binding ChiTietDatVe.SoDienThoai, TargetNullValue=--}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Ngày hủy"/>
                                <TextBlock Foreground="#102A43" FontWeight="SemiBold" Text="{Binding ChiTietDatVe.NgayHuyText, TargetNullValue=--}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Tổng tiền"/>
                                <TextBlock Foreground="#D64545" FontWeight="Bold" Text="{Binding ChiTietDatVe.GiaText, TargetNullValue=--}"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Background="#F8FBFF" BorderBrush="#E3EDF7" BorderThickness="1" CornerRadius="14">
                            <Grid>
                                <DataGrid x:Name="GheDataGrid"
                                          Style="{StaticResource AdminDataGridStyle}"
                                          ItemsSource="{Binding DanhSachGhe}"
                                          IsReadOnly="True"
                                          ColumnHeaderStyle="{StaticResource AdminDataGridHeaderStyle}"
                                          CellStyle="{StaticResource AdminDataGridCellStyle}"
                                          RowStyle="{StaticResource AdminDataGridRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                                        <DataGridTextColumn Header="Ghế" Binding="{Binding SoGhe}" Width="120"/>
                                        <DataGridTextColumn Header="Loại vé" Binding="{Binding LoaiVeText}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Background="#F8FBFF"
                                        Visibility="{Binding ElementName=GheDataGrid, Path=HasItems, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontSize="34"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="#9FB3C8"
                                                   HorizontalAlignment="Center"
                                                   Text="&#xE7F8;"/>
                                        <TextBlock Margin="0,10,0,0"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AdminHeadingText}"
                                                   HorizontalAlignment="Center"
                                                   Text="Chưa có danh sách ghế"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Thao tác nhanh"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Trạng thái mới"/>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding TrangThaiOptions}"
                                          SelectedItem="{Binding TrangThaiMoi, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="0,21,10,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding XemChiTietCommand}"
                                    Content="Tải lại chi tiết"/>
                            <Button Grid.Column="2"
                                    Margin="0,21,10,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding CapNhatTrangThaiCommand}"
                                    Content="Cập nhật trạng thái"/>
                            <Button Grid.Column="3"
                                    Margin="0,21,0,0"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding InChiTietVeCommand}"
                                    Content="In PDF"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
