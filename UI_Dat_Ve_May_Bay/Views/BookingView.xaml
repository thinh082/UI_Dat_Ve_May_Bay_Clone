<UserControl x:Class="UI_Dat_Ve_May_Bay.Views.BookingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:UI_Dat_Ve_May_Bay.ViewModels"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             d:DataContext="{d:DesignInstance Type=viewmodels:BookingViewModel}"
             mc:Ignorable="d"
             Loaded="BookingView_Loaded"
             Unloaded="BookingView_Unloaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Color Palette -->
        <LinearGradientBrush x:Key="VnaGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00548B" Offset="0"/>
            <GradientStop Color="#008291" Offset="1"/>
        </LinearGradientBrush>

        <!-- Seat Styles -->
        <Style TargetType="ToggleButton" x:Key="SeatToggle">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" CornerRadius="12" BorderThickness="1.5" Background="White" BorderBrush="#E5E7EB">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#4B5563"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                                <!-- Indicator for selected -->
                                <Border x:Name="indicator" Width="6" Height="6" CornerRadius="3" Background="White" 
                                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,6,0" Opacity="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover effect (chỉ khi enabled) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#008291"/>
                            </Trigger>
                            
                            <!-- 1. HẾT CHỖ (Đỏ nhạt #FFD6D6): Đã đặt + đã thanh toán (IsEnabled = False, IsBookedByMe = False) -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FFD6D6"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FCA5A5"/>
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="Foreground" Value="#991B1B"/>
                            </Trigger>
                            
                            <!-- 2. ĐANG GIỮ CHỖ (Vàng nhạt #FFEBB7): Người khác đang giữ, chưa thanh toán (IsReserved = True) -->
                            <DataTrigger Binding="{Binding IsReserved}" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFEBB7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FCD34D"/>
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="Foreground" Value="#92400E"/>
                            </DataTrigger>
                            
                            <!-- 3. ĐÃ CHỌN (Xanh lá #28B463): Người dùng hiện tại đang chọn (IsChecked = True) - ƯU TIÊN CAO NHẤT -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#28B463"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E8449"/>
                                <Setter TargetName="indicator" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- TabControl Styles -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Margin="0,0,16,0" Padding="0,8,0,12" BorderThickness="0,0,0,3" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" TextBlock.FontWeight="SemiBold" TextBlock.FontSize="14" TextBlock.Foreground="#6B7280"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#008291"/>
                                <Setter Property="TextBlock.Foreground" Value="#00548B"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="#008291"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR (HERO) -->
        <Border Grid.Row="0" Background="{StaticResource VnaGradient}" Padding="32,24" Height="140">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Command="{Binding BackCommand}" Style="{StaticResource TopNavButtonStyle}" Padding="10,0" Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="←" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Quay lại" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Chuyến bay của bạn" Foreground="#E0EEFF" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock Text="Chọn chỗ ngồi &amp; Thanh toán" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#1AFFFFFF" CornerRadius="12" Padding="20,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Trạng thái:" Foreground="#E0EEFF" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="ĐANG CHỜ" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32, -40, 32, 32">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <StackPanel Grid.Column="0">
                    <!-- Flight Detail Card -->
                    <Border Style="{StaticResource Card}" Height="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#EFF6FF" CornerRadius="8" Padding="10,6" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding SelectedSchedule.HangBayName}" Foreground="#00548B" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="Mã hiệu: VN-241" Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedSchedule.MaSanBayDi}" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                                        <TextBlock Text="{Binding SelectedSchedule.GioDi}" Foreground="#6B7280" FontSize="14"/>
                                    </StackPanel>

                                    <Grid Grid.Column="1" Margin="10,0">
                                        <Rectangle Height="2" Fill="#E5E7EB" VerticalAlignment="Center" Margin="0, -10, 0, 0"/>
                                        <Ellipse Width="8" Height="8" Fill="#008291" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0, -10, 0, 0"/>
                                        <TextBlock Text="BAY THẲNG" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="10" FontWeight="Bold" Foreground="#9CA3AF"/>
                                    </Grid>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding SelectedSchedule.MaSanBayDen}" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                                        <TextBlock Text="{Binding SelectedSchedule.GioDen}" Foreground="#6B7280" FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            
                            <Border Grid.Column="1" Background="#F0FDF4" CornerRadius="12" Padding="20,16" VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Đã chọn" Foreground="#166534" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedSeatCount}" Foreground="#15803D" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Ghế" Foreground="#166534" FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Seat Map Card -->
                    <Border Style="{StaticResource Card}" Margin="0,24,0,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="#F1F5F9" CornerRadius="16,16,0,0" Padding="24,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Sơ đồ cabin" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                                        <TextBlock Text="Lựa chọn vị trí ngồi ưa thích của bạn" Foreground="#64748B" FontSize="13"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Làm mới sơ đồ" Command="{Binding RefreshSeatsCommand}"
                                            Style="{StaticResource VnaPrimaryBtn}" Padding="16,8" FontSize="12"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="1" Margin="24">
                                <!-- Legend -->
                                <WrapPanel Margin="0,0,0,24">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                        <Border Width="16" Height="16" CornerRadius="4" Background="#FFD6D6" BorderBrush="#FCA5A5" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBlock Text="Hết chỗ" Foreground="#991B1B" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                        <Border Width="16" Height="16" CornerRadius="4" Background="#FFEBB7" BorderBrush="#FCD34D" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBlock Text="Đang giữ chỗ" Foreground="#92400E" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                        <Border Width="16" Height="16" CornerRadius="4" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBlock Text="Trống" Foreground="#64748B" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="16" Height="16" CornerRadius="4" Background="#28B463" BorderBrush="#1E8449" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBlock Text="Đã chọn" Foreground="#64748B" FontSize="13"/>
                                    </StackPanel>
                                </WrapPanel>

                                <TabControl>
                                    <TabItem Header="PHỔ THÔNG">
                                        <ItemsControl ItemsSource="{Binding SeatRowsLoai1}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding RowLabel}" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding LeftSeats}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                     <ToggleButton Style="{StaticResource SeatToggle}" Content="{Binding SoGhe}" IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsAvailable}" Checked="Seat_Checked" Unchecked="Seat_Unchecked"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        
                                                        <Border Grid.Column="2" Background="#F1F5F9" Width="30" CornerRadius="4" Margin="10,0"/>

                                                        <ItemsControl Grid.Column="3" ItemsSource="{Binding RightSeats}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <ToggleButton Style="{StaticResource SeatToggle}" Content="{Binding SoGhe}" IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsAvailable}" Checked="Seat_Checked" Unchecked="Seat_Unchecked"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </TabItem>

                                    <TabItem Header="THƯƠNG GIA">
                                        <ItemsControl ItemsSource="{Binding SeatRowsLoai3}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding RowLabel}" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding LeftSeats}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate><DataTemplate>
                                                                <ToggleButton Style="{StaticResource SeatToggle}" Content="{Binding SoGhe}" IsChecked="{Binding IsSelected}" Checked="Seat_Checked" Unchecked="Seat_Unchecked"/>
                                                            </DataTemplate></ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Border Grid.Column="2" Background="#F1F5F9" Width="30" CornerRadius="4" Margin="10,0"/>
                                                        <ItemsControl Grid.Column="3" ItemsSource="{Binding RightSeats}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate><DataTemplate>
                                                                <ToggleButton Style="{StaticResource SeatToggle}" Content="{Binding SoGhe}" IsChecked="{Binding IsSelected}" Checked="Seat_Checked" Unchecked="Seat_Unchecked"/>
                                                            </DataTemplate></ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </TabItem>

                                    <TabItem Header="HANG NHẤT">
                                        <ItemsControl ItemsSource="{Binding SeatRowsLoai4}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding RowLabel}" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding LeftSeats}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate><DataTemplate>
                                                                <ToggleButton Style="{StaticResource SeatToggle}" Content="{Binding SoGhe}" IsChecked="{Binding IsSelected}" Checked="Seat_Checked" Unchecked="Seat_Unchecked"/>
                                                            </DataTemplate></ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Border Grid.Column="2" Background="#F1F5F9" Width="30" CornerRadius="4" Margin="10,0"/>
                                                        <ItemsControl Grid.Column="3" ItemsSource="{Binding RightSeats}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate><DataTemplate>
                                                                <ToggleButton Style="{StaticResource SeatToggle}" Content="{Binding SoGhe}" IsChecked="{Binding IsSelected}" Checked="Seat_Checked" Unchecked="Seat_Unchecked"/>
                                                            </DataTemplate></ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </TabItem>
                                </TabControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <TextBlock Margin="0,16,0,0" Foreground="#DC2626" TextWrapping="Wrap" Text="{Binding Error}" FontWeight="SemiBold"/>
                    <TextBlock Margin="0,8,0,0" Foreground="#10B981" TextWrapping="Wrap" Text="{Binding Info}" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- RIGHT SIDE (SIDEBAR) -->
                <StackPanel Grid.Column="2">
                    <!-- Price Summary Card -->
                    <Border Style="{StaticResource SidebarCard}">
                        <StackPanel>
                            <TextBlock Text="Chi tiết đặt vé" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,20"/>
                            
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Tạm tính" Foreground="#64748B"/>
                                <TextBlock HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="SemiBold">
                                    <Run Text="{Binding Subtotal, StringFormat={}{0:n0}}"/><Run Text=" đ"/>
                                </TextBlock>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Khuyến mãi" Foreground="#64748B"/>
                                <TextBlock HorizontalAlignment="Right" Foreground="#10B981" FontWeight="SemiBold">
                                    <Run Text="- "/><Run Text="{Binding Discount, StringFormat={}{0:n0}}"/><Run Text=" đ"/>
                                </TextBlock>
                            </Grid>

                            <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                                <Grid>
                                    <TextBlock Text="TỔNG CỘNG" Foreground="#1E293B" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Right" Foreground="#00548B" FontSize="22" FontWeight="Bold">
                                        <Run Text="{Binding Total, StringFormat={}{0:n0}}"/><Run Text=" đ"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Voucher Card -->
                    <Border Style="{StaticResource SidebarCard}">
                        <StackPanel>
                            <TextBlock Text="Voucher ưu đãi" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding VoucherCode, UpdateSourceTrigger=PropertyChanged}" 
                                         Tag="Nhập mã..." Padding="12,8" Height="40" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="Áp dụng" Margin="8,0,0,0" 
                                        Style="{StaticResource VnaPrimaryBtn}" Padding="0" FontSize="11"
                                        Command="{Binding ApplyVoucherCommand}"/>
                            </Grid>

                            <ComboBox ItemsSource="{Binding MyVouchers}" SelectedItem="{Binding SelectedVoucher}" 
                                      DisplayMemberPath="DisplayText" Height="40" Margin="0,0,0,8" VerticalContentAlignment="Center"/>
                            
                            <Button Content="Huỷ bỏ voucher" Command="{Binding ClearVoucherCommand}" 
                                    Background="Transparent" BorderThickness="0" Foreground="#94A3B8" FontSize="12" Cursor="Hand" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Payment Method -->
                    <Border Style="{StaticResource SidebarCard}">
                        <StackPanel>
                            <TextBlock Text="Phương thức thanh toán" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                            
                            <ComboBox ItemsSource="{Binding PaymentOptions}" SelectedItem="{Binding SelectedPayment}" 
                                      Height="45" Margin="0,0,0,20" VerticalContentAlignment="Center"/>

                            <Button Content="XÁC NHẬN ĐẶT VÉ" Command="{Binding BookCommand}" 
                                    Height="50" FontSize="14" FontWeight="Bold"
                                    Background="{StaticResource VnaPrimaryBlue}" BorderThickness="0" Foreground="White">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <TextBlock Margin="0,16,0,0" Foreground="#64748B" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"
                                       Text="Bằng việc nhấn đặt vé, bạn đồng ý với các điều khoản và chính sách của chúng tôi."/>
                        </StackPanel>
                    </Border>
                    
                    <!-- History (Optional / Minimal) -->
                    <Border Style="{StaticResource SidebarCard}" Opacity="0.8">
                        <StackPanel>
                            <TextBlock Text="Lịch sử giao dịch" FontSize="14" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding PaymentHistory}" DisplayMemberPath="DisplayLine" 
                                     Background="Transparent" BorderThickness="0" MaxHeight="100">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </Style>
                                </ListBox.Resources>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Overlay WebView2 thanh toán -->
        <Grid Grid.RowSpan="2" Background="#99000000" Visibility="{Binding IsWaitingPayment, Converter={StaticResource BoolToVis}}">
            <Border Width="1100" Height="680" Background="White" CornerRadius="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#111827" CornerRadius="20,20,0,0" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="White" FontWeight="Bold" FontSize="18" Text="Thanh toán trực tuyến"/>
                                <TextBlock Foreground="#9CA3AF" FontSize="13" Text="Hệ thống đang xử lý giao dịch an toàn"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Kiểm tra" Margin="0,0,12,0" Style="{StaticResource VnaPrimaryBtn}" Command="{Binding CheckPaymentStatusCommand}"/>
                                <Button Content="Đã thanh toán" Margin="0,0,12,0" Style="{StaticResource VnaPrimaryBtn}" Command="{Binding ConfirmPaymentCommand}"/>
                                <Button Content="Đóng" Padding="16,8" Click="ClosePaymentOverlay_Click" Background="#374151" BorderThickness="0" Foreground="White" Cursor="Hand">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <wv2:WebView2 x:Name="PaymentWeb" Grid.Row="1" Margin="12"/>

                    <Border Grid.Row="2" Background="#F9FAFB" Padding="24,16" CornerRadius="0,0,20,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Foreground="#4B5563" FontWeight="SemiBold" Text="{Binding LatestPaymentStatus}"/>
                            <Button Grid.Column="1" Content="Mở trình duyệt ngoài" Background="Transparent" BorderThickness="0" Foreground="#008291" Cursor="Hand" Command="{Binding OpenPaymentLinkCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
