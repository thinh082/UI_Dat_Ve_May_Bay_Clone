<Window x:Class="UI_Dat_Ve_May_Bay.Views.Components.SocialLoginWebViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Social Login"
        Width="520"
        Height="760"
        MinWidth="420"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Window.Resources>
        <Style x:Key="ToolbarButtonBaseStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#93C5FD" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#BFDBFE" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E5E7EB" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonPrimaryStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonBaseStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E3A8A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#9CA3AF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#9CA3AF" />
                                <Setter Property="Foreground" Value="#F3F4F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="12,10"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="HeaderText"
                           Text="Complete social sign in"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BackButton"
                            Style="{StaticResource ToolbarButtonBaseStyle}"
                            Click="BackButton_Click"
                            ToolTip="Go back">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Back" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ReloadButton"
                            Style="{StaticResource ToolbarButtonPrimaryStyle}"
                            Click="ReloadButton_Click"
                            ToolTip="Reload page">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Reload" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <wv2:WebView2 x:Name="Browser" />
            <Border x:Name="LoadingOverlay"
                    Background="#66FFFFFF"
                    Visibility="Collapsed">
                <TextBlock Text="Loading..."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#374151"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
