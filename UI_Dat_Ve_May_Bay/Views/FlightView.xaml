<UserControl x:Class="UI_Dat_Ve_May_Bay.Views.FlightView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:UI_Dat_Ve_May_Bay.Core"
             mc:Ignorable="d"
             Background="#FFF8FAFC"
             Language="vi-VN">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <core:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>

        <!-- ===== Local Styles ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource VnaBorderGray}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.06" Color="#001A36"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Background" Value="{StaticResource VnaPrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FFCBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource VnaPrimaryBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VnaPrimaryBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource VnaLightBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource VnaBorderGray}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource VnaTextGray}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource VnaBorderGray}"/>
            <Setter Property="Margin" Value="0,16"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Hero Search Section -->
            <RowDefinition Height="*"/>
            <!-- Results -->
        </Grid.RowDefinitions>

        <!-- ======= HERO SEARCH SECTION ======= -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00548B" Offset="0"/>
                    <GradientStop Color="#0077B6" Offset="0.5"/>
                    <GradientStop Color="#008291" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="✈  Tìm Chuyến Bay" FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Khám phá hàng trăm chuyến bay với giá tốt nhất mỗi ngày" 
                               Foreground="#B3DAFF" FontSize="13" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Main Search Bar -->
                <Border Grid.Row="2" Background="White" CornerRadius="14" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.2" Color="#001A36"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <!-- Điểm đi -->
                        <StackPanel Grid.Column="0" Margin="20,16">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="ĐIỂM ĐI"/>
                            <ComboBox ItemsSource="{Binding Airports}"
                                      SelectedItem="{Binding SelectedFromAirport}"
                                      DisplayMemberPath="Display"
                                      BorderThickness="0" Background="Transparent"
                                      FontSize="17" FontWeight="Bold"
                                      Foreground="{StaticResource VnaTextDark}"
                                      Height="28" Padding="0"/>
                        </StackPanel>

                        <!-- Swap Button -->
                        <Button Grid.Column="1" Command="{Binding SwapAirportsCommand}"
                                Width="40" Height="40" Margin="-2,0" Panel.ZIndex="10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource VnaLightBlue}" CornerRadius="20"
                                            BorderBrush="#B3D4F0" BorderThickness="1" x:Name="bd">
                                        <TextBlock Text="⇄" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource VnaPrimaryBlue}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Điểm đến -->
                        <StackPanel Grid.Column="2" Margin="20,16">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="ĐIỂM ĐẾN"/>
                            <ComboBox ItemsSource="{Binding Airports}"
                                      SelectedItem="{Binding SelectedToAirport}"
                                      DisplayMemberPath="Display"
                                      BorderThickness="0" Background="Transparent"
                                      FontSize="17" FontWeight="Bold"
                                      Foreground="{StaticResource VnaTextDark}"
                                      Height="28" Padding="0"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Grid.Column="3" Style="{StaticResource Divider}"/>

                        <!-- Ngày đi -->
                        <StackPanel Grid.Column="4" Margin="20,16">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="NGÀY ĐI"/>
                            <DatePicker SelectedDate="{Binding NgayDi, Mode=TwoWay}"
                                        BorderThickness="0" Background="Transparent"
                                        FontSize="15" FontWeight="SemiBold"
                                        Foreground="{StaticResource VnaTextDark}"
                                        Height="28"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Grid.Column="5" Style="{StaticResource Divider}"/>

                        <!-- Search Button -->
                        <Button Grid.Column="6" Margin="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                    <Setter Property="Content" Value="🔍  TÌM CHUYẾN BAY"/>
                                    <Setter Property="Command" Value="{Binding SearchCommand}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Content" Value="⏳  ĐANG TÌM..."/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Filter Bar -->
                <Border Grid.Row="4">
                    <DockPanel LastChildFill="False">
                        <!-- Error Pill -->
                        <Border DockPanel.Dock="Left"
                                Background="#CC2626" CornerRadius="20" Padding="14,6" Margin="0,0,16,0"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠  " Foreground="White" FontSize="12"/>
                                <TextBlock Text="{Binding Error}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <TextBlock Text="Hãng bay:" VerticalAlignment="Center" Foreground="White" 
                                       Margin="0,0,8,0" FontWeight="SemiBold" FontSize="13" Opacity="0.9"/>
                            <ComboBox ItemsSource="{Binding Airlines}" SelectedItem="{Binding SelectedAirline}"
                                      DisplayMemberPath="Name" Width="160" Margin="0,0,10,0"
                                      Style="{StaticResource FilterCombo}"/>

                            <TextBlock Text="Tiện ích:" VerticalAlignment="Center" Foreground="White"
                                       Margin="0,0,8,0" FontWeight="SemiBold" FontSize="13" Opacity="0.9"/>
                            <ComboBox ItemsSource="{Binding Amenities}" SelectedItem="{Binding SelectedAmenity}"
                                      DisplayMemberPath="Name" Width="150" Margin="0,0,10,0"
                                      Style="{StaticResource FilterCombo}"/>

                            <TextBlock Text="Giá từ:" VerticalAlignment="Center" Foreground="White"
                                       Margin="0,0,8,0" FontWeight="SemiBold" FontSize="13" Opacity="0.9"/>
                            <Border Background="White" CornerRadius="6" Padding="0" Height="34" Width="90" Margin="0,0,6,0">
                                <TextBox Text="{Binding GiaMin, StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus}" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>
                            </Border>
                            <TextBlock Text="—" VerticalAlignment="Center" Foreground="White" Margin="0,0,6,0" FontWeight="Bold"/>
                            <Border Background="White" CornerRadius="6" Padding="0" Height="34" Width="110" Margin="0,0,16,0">
                                <TextBox Text="{Binding GiaMax, StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus}" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>
                            </Border>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="Sắp xếp:" VerticalAlignment="Center" Foreground="White"
                                       Margin="0,0,8,0" FontWeight="SemiBold" FontSize="13" Opacity="0.9"/>
                            <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"
                                      Width="180" Style="{StaticResource FilterCombo}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ======= RESULTS SECTION ======= -->
        <Grid Grid.Row="1" Margin="28,20,28,20">

            <!-- Loading Overlay -->
            <Border CornerRadius="16" Background="#F0F8FF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="✈" FontSize="56" Foreground="{StaticResource VnaPrimaryBlue}"
                               HorizontalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="PlaneTranslate"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="Đang tìm kiếm chuyến bay..." FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource VnaPrimaryBlue}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="Vui lòng chờ trong giây lát..." Foreground="{StaticResource VnaTextGray}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Initial / Empty State -->
            <Border CornerRadius="16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NoResultsFound}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#EFF6FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="✈" FontSize="80" Foreground="#BFDBFE" HorizontalAlignment="Center"/>
                    <TextBlock Text="Chưa có kết quả tìm kiếm" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource VnaTextDark}" HorizontalAlignment="Center" Margin="0,20,0,8"/>
                    <TextBlock Text="Nhập điểm đi, điểm đến, ngày bay và nhấn &quot;Tìm chuyến bay&quot; để bắt đầu."
                               Foreground="{StaticResource VnaTextGray}" HorizontalAlignment="Center" FontSize="14"
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                </StackPanel>
            </Border>

            <!-- Results List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NoResultsFound}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Results}" Margin="0,0,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,28">
                                <!-- Airline Group Header -->
                                <Border CornerRadius="10" Padding="16,10" Margin="0,0,0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#EFF6FF" Offset="0"/>
                                            <GradientStop Color="#F0FDFA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Header}" FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource VnaPrimaryBlue}" VerticalAlignment="Center"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Schedules.Count, StringFormat='{}{0} chuyến'}"
                                                   FontSize="12" Foreground="{StaticResource VnaTextGray}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                </Border>

                                <!-- Flight Cards -->
                                <ItemsControl ItemsSource="{Binding Schedules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#93C5FD"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border x:Name="cardInner" CornerRadius="16" Padding="24,20">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="160"/>
                                                            <!-- Time -->
                                                            <ColumnDefinition Width="*"/>
                                                            <!-- Route -->
                                                            <ColumnDefinition Width="Auto"/>
                                                            <!-- Amenities -->
                                                            <ColumnDefinition Width="160"/>
                                                            <!-- Price+CTA -->
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Left: Time block -->
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayTime}"
                                                                       FontSize="20" FontWeight="Bold"
                                                                       Foreground="{StaticResource VnaTextDark}"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                <Border Background="{StaticResource VnaLightBlue}" CornerRadius="4" Padding="6,2">
                                                                    <TextBlock Text="{Binding ThoiGianBay, StringFormat='{}{0} phút'}"
                                                                               FontSize="11" Foreground="{StaticResource VnaPrimaryBlue}"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Center: Route Visualization -->
                                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="30,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding MaSanBayDi}" FontWeight="Bold"
                                                                           FontSize="18" HorizontalAlignment="Center"
                                                                           Foreground="{StaticResource VnaTextDark}"/>
                                                                <TextBlock Text="{Binding TenSanBayDi}" FontSize="10"
                                                                           Foreground="{StaticResource VnaTextGray}"
                                                                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="80"/>
                                                            </StackPanel>

                                                            <!-- Timeline -->
                                                            <Grid Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                                                <Line X1="0" X2="1" Y1="0" Y2="0" Stretch="Fill"
                                                                      StrokeThickness="1.5" StrokeDashArray="4,4">
                                                                    <Line.Stroke>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                            <GradientStop Color="#00548B" Offset="0"/>
                                                                            <GradientStop Color="#008291" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Line.Stroke>
                                                                </Line>
                                                                <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center"
                                                                        BorderThickness="2">
                                                                    <Border.Background>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="#00548B" Offset="0"/>
                                                                            <GradientStop Color="#008291" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Border.Background>
                                                                    <Border.BorderBrush>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="#00548B" Offset="0"/>
                                                                            <GradientStop Color="#008291" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Border.BorderBrush>
                                                                    <TextBlock Text="✈" Foreground="White"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" FontSize="13"/>
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding MaSanBayDen}" FontWeight="Bold"
                                                                           FontSize="18" HorizontalAlignment="Center"
                                                                           Foreground="{StaticResource VnaTextDark}"/>
                                                                <TextBlock Text="{Binding TenSanBayDen}" FontSize="10"
                                                                           Foreground="{StaticResource VnaTextGray}"
                                                                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="80"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <!-- Amenities + Seats -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="24,0">
                                                            <TextBlock Text="{Binding SoLuongGhe, StringFormat='{}Còn {0} ghế'}"
                                                                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Right">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding SoLuongGhe}" Value="0">
                                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding TienIchText}"
                                                                       FontSize="11" Foreground="{StaticResource VnaTextGray}"
                                                                       Margin="0,5,0,0" TextAlignment="Right"
                                                                       MaxWidth="160" TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <!-- Price + CTA -->
                                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Width="150">
                                                            <TextBlock Text="{Binding DisplayPrice}"
                                                                       FontSize="22" FontWeight="Bold"
                                                                       HorizontalAlignment="Right">
                                                                <TextBlock.Foreground>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#00548B" Offset="0"/>
                                                                        <GradientStop Color="#008291" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </TextBlock.Foreground>
                                                            </TextBlock>
                                                            <TextBlock Text="/người" FontSize="11"
                                                                       Foreground="{StaticResource VnaTextGray}"
                                                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                            <Button Margin="0,12,0,0" Height="38"
                                                                    Command="{Binding DataContext.SelectScheduleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                                                        <Setter Property="Content" Value="CHỌN CHUYẾN"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Background" Value="#16A34A"/>
                                                                                <Setter Property="Content" Value="✓  ĐÃ CHỌN"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>