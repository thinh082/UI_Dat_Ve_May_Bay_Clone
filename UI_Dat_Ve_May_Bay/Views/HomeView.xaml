<UserControl x:Class="UI_Dat_Ve_May_Bay.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="1200"
             Background="#F8FAFC">
    <UserControl.Resources>
        <!-- Modern Shadows -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="4" Opacity="0.06" Color="#001A36"/>
        <DropShadowEffect x:Key="HeroShadow" BlurRadius="30" ShadowDepth="10" Opacity="0.15" Color="#004675"/>

        <!-- Action Card Style -->
        <Style x:Key="ActionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Modern Input -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource VnaPrimaryBlue}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">

            <!-- Hero Banner Section -->
            <Grid Margin="0,0,0,40">
                <Border CornerRadius="28" Height="320" Background="{StaticResource SidebarBg}" Effect="{StaticResource HeroShadow}" ClipToBounds="True">
                    <Grid>
                        <!-- Banner Image (Mocked with Gradient if file not found, but using placeholder) -->
                        <Border x:Name="BannerBorder">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00548B" Offset="0"/>
                                    <GradientStop Color="#008291" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Decorative Accents -->
                        <Ellipse Fill="White" Width="400" Height="400" Opacity="0.04" Margin="-200,-200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Ellipse Fill="White" Width="300" Height="300" Opacity="0.03" Margin="0,0,-150,-150" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

                        <!-- Text Overlay -->
                        <StackPanel VerticalAlignment="Center" Margin="48">
                            <TextBlock Text="{Binding Greeting}" FontSize="18" Foreground="#BEE3F8" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Question}" FontSize="40" Foreground="White" FontWeight="Bold" Margin="0,12,0,0" MaxWidth="600" TextWrapping="Wrap"/>
                            <TextBlock Text="Khám phá ưu đãi đặc biệt dành riêng cho bạn hôm nay." FontSize="14" Foreground="#E0F2FE" Margin="4,16,0,0" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Quick Search Bar Overlay -->
                <Border VerticalAlignment="Bottom" Height="80" Margin="64,0,64,-40" Background="White" CornerRadius="16" Effect="{StaticResource CardShadow}" BorderBrush="#F1F5F9" BorderThickness="1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mock Search Inputs to guide user -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="ĐIỂM ĐI" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                            <TextBlock Text="TP. Hồ Chí Minh" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="1" Background="#E2E8F0" Height="32" Margin="20,0"/>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="ĐIỂM ĐẾN" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                            <TextBlock Text="Hà Nội" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="3" Width="1" Background="#E2E8F0" Height="32" Margin="20,0"/>

                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                            <TextBlock Text="NGÀY ĐI" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                            <TextBlock Text="27 Tháng 3, 2026" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,2,0,0"/>
                        </StackPanel>
                        
                        <Button Grid.Column="6" Content="TÌM NGAY" Style="{StaticResource VnaPrimaryBtn}" Height="46" 
                                Command="{Binding DataContext.GoFlightCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Spacing for Overlay -->
            <Border Height="60"/>

            <!-- Action Section (Split layout) -->
            <Grid Margin="0,0,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cancellation Card -->
                <Border Grid.Column="0" Style="{StaticResource ActionCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="#FEF2F2" Width="48" Height="48" CornerRadius="12">
                                <TextBlock Text="✖" Foreground="#EF4444" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Quản lý Booking" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Huỷ dịch vụ đã đặt" FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <TextBlock Text="MÃ ĐẶT VÉ (ID)" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding BookingIdText}" d:Text="BK-9921"/>
                        
                        <TextBlock Text="LÝ DO HUỶ" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,16,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding CancelReason}" d:Text="Bận việc gia đình..."/>
                        
                        <Button Content="Gửi yêu cầu huỷ ngay" Style="{StaticResource VnaPrimaryBtn}" Margin="0,24,0,0" Height="48" 
                                Command="{Binding CancelBookingCommand}" Background="#EF4444">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Check-in Card -->
                <Border Grid.Column="1" Style="{StaticResource ActionCardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="#F0FDF4" Width="48" Height="48" CornerRadius="12">
                                <TextBlock Text="✔" Foreground="#22C55E" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Check-in Online" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Tiết kiệm thời gian tại sân bay" FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <TextBlock Text="MÃ XÁC NHẬN" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding CheckInIdText}" d:Text="CHKIN-882"/>
                        
                        <Border Background="#EFF6FF" CornerRadius="12" Padding="16" Margin="0,20,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💡" Margin="0,0,12,0"/>
                                <TextBlock Text="Bạn có thể check-in trước 24h so với giờ khởi hành." FontSize="11" Foreground="#1E40AF" TextWrapping="Wrap" MaxWidth="180"/>
                            </StackPanel>
                        </Border>
                        
                        <Button Content="Làm thủ tục ngay" Style="{StaticResource VnaPrimaryBtn}" Margin="0,29,0,0" Height="48" 
                                Command="{Binding CheckInCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>



            <Border Height="40" Background="Transparent"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>