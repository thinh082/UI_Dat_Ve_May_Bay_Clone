<Window x:Class="UI_Dat_Ve_May_Bay.Views.PolicyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:UI_Dat_Ve_May_Bay.ViewModels"
        mc:Ignorable="d"
        Title="Chính Sách và Điều Khoản Dịch Vụ"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Segoe UI"
        d:DataContext="{d:DesignInstance Type=viewmodels:PolicyViewModel}">

    <Window.Resources>
        <Style x:Key="AgreeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0D6EFD"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#0B5ED7"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="PolicyScrollViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="#F8F9FA">
            <StackPanel Margin="32" MaxWidth="600">
                <TextBlock Text="CHÍNH SÁCH VÀ ĐIỀU KHOẢN DỊCH VỤ"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#212529"
                           Margin="0,0,0,24"
                           TextAlignment="Center"/>

                <TextBlock Text="Để bảo đảm quá trình đặt vé diễn ra rõ ràng, minh bạch và hạn chế phát sinh sai sót, hệ thống áp dụng một số chính sách cụ thể đối với khách hàng trong suốt quá trình tìm chuyến bay, chọn ghế, đặt vé, thanh toán và hủy vé. Khi sử dụng dịch vụ, khách hàng được xem là đã đọc và đồng ý với các điều khoản dưới đây."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="1. Điều khoản chung" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Khách hàng cần cung cấp đúng thông tin khi đăng ký tài khoản, đăng nhập và đặt vé. Mọi thông tin hành khách phải được nhập chính xác để tránh ảnh hưởng đến quá trình xác nhận vé và làm thủ tục chuyến bay. Hệ thống có quyền từ chối xử lý đối với các trường hợp thông tin không đầy đủ, không hợp lệ hoặc có dấu hiệu sai lệch."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="2. Chính sách tìm kiếm và đặt vé" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Hệ thống cho phép khách hàng tìm kiếm chuyến bay theo các tiêu chí cơ bản như điểm đi, điểm đến, ngày bay và số lượng hành khách. Sau khi chọn được chuyến bay phù hợp, khách hàng có thể tiếp tục chọn ghế, nhập thông tin hành khách và tạo đơn đặt vé.&#10;&#10;Để bảo đảm quyền lợi cho người dùng, hệ thống áp dụng các quy định sau:&#10;• Khách hàng chỉ có thể đặt vé khi đã chọn đúng chuyến bay và ghế còn trống.&#10;• Vé chỉ được xác nhận khi khách hàng hoàn tất thanh toán thành công.&#10;• Đơn đặt vé chưa thanh toán sẽ chưa được xem là vé hợp lệ."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="3. Chính sách giữ ghế" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Khi khách hàng chọn ghế, hệ thống sẽ giữ ghế tạm thời trong 5 phút để khách hàng có thời gian hoàn tất các bước tiếp theo. Trong khoảng thời gian này, ghế đã chọn sẽ không hiển thị là ghế trống cho người dùng khác.&#10;&#10;Quy định giữ ghế được áp dụng như sau:&#10;• Thời gian giữ ghế tạm thời là 10 phút kể từ lúc chọn ghế.&#10;• Nếu khách hàng không tiếp tục thao tác hoặc thoát giữa chừng, ghế sẽ tự động được mở lại.&#10;• Nếu ghế đã được người khác giữ trước, khách hàng sẽ không thể chọn ghế đó.&#10;• Việc giữ ghế không đồng nghĩa với việc vé đã được xác nhận thành công."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="4. Chính sách thanh toán" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Sau khi hoàn tất bước chọn ghế và nhập thông tin hành khách, khách hàng sẽ chuyển sang bước thanh toán. Hệ thống chỉ xác nhận vé khi giao dịch thanh toán được thực hiện thành công.&#10;&#10;Các quy định thanh toán gồm:&#10;• Đơn đặt vé sẽ được giữ ở trạng thái chờ thanh toán trong 15 phút.&#10;• Nếu quá 15 phút mà khách hàng chưa thanh toán thành công, đơn có thể hết hiệu lực.&#10;• Trường hợp thanh toán không thành công, hệ thống sẽ không xác nhận vé.&#10;• Khách hàng cần kiểm tra kỹ số tiền và thông tin đơn hàng trước khi xác nhận thanh toán."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="5. Chính sách xác nhận vé" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Sau khi thanh toán thành công, hệ thống sẽ ghi nhận giao dịch và xác nhận đặt vé cho khách hàng. Khi đó, vé mới được xem là hợp lệ và có thể dùng cho các bước tiếp theo.&#10;&#10;Khách hàng cần lưu ý:&#10;• Vé chỉ có giá trị khi hệ thống hiển thị trạng thái đặt vé thành công.&#10;• Sau khi xác nhận, thông tin vé cần được lưu lại để tra cứu khi cần.&#10;• Khách hàng nên kiểm tra lại thông tin vé ngay sau khi giao dịch hoàn tất."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="6. Chính sách hủy vé" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Hệ thống cho phép khách hàng hủy vé trong phạm vi điều kiện được chấp nhận. Tuy nhiên, không phải mọi vé đều có thể hủy ở mọi thời điểm.&#10;&#10;Các trường hợp áp dụng gồm:&#10;• Khách hàng không được hủy vé nếu thời điểm hủy còn dưới 24 giờ trước giờ khởi hành.&#10;• Vé đã check-in sẽ không được hủy.&#10;• Vé đã hủy trước đó sẽ không thể tiếp tục hủy lại.&#10;• Nếu hủy vé thành công, trạng thái vé sẽ được cập nhật tương ứng trên hệ thống."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="7. Chính sách check-in" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Sau khi vé được xác nhận, khách hàng có thể sử dụng vé để thực hiện các bước tiếp theo của chuyến đi. Khi vé đã được check-in, hệ thống sẽ cập nhật trạng thái của vé nhằm tránh việc sử dụng lặp hoặc hủy vé không hợp lệ.&#10;&#10;Cụ thể:&#10;• Vé sau khi check-in sẽ được ghi nhận là đã sử dụng cho bước làm thủ tục.&#10;• Vé đã check-in sẽ không được hủy.&#10;• Khách hàng cần kiểm tra kỹ thông tin trước khi thực hiện check-in."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="8. Chính sách thông tin tài khoản và dữ liệu giao dịch" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Khách hàng có trách nhiệm bảo mật tài khoản và mật khẩu của mình. Hệ thống lưu trữ các thông tin cần thiết như thông tin khách hàng, mã đặt vé, trạng thái vé và trạng thái thanh toán để phục vụ tra cứu và hỗ trợ giao dịch.&#10;&#10;Khách hàng cần lưu ý:&#10;• Không chia sẻ tài khoản cho người khác.&#10;• Kiểm tra kỹ thông tin trước khi xác nhận đặt vé.&#10;• Chủ động theo dõi trạng thái giao dịch trên hệ thống sau mỗi bước thao tác."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,20" LineHeight="20"/>

                <TextBlock Text="9. Chính sách hỗ trợ khách hàng" FontSize="14" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                <TextBlock Text="Trong trường hợp phát sinh lỗi khi đặt vé, thanh toán hoặc tra cứu giao dịch, khách hàng cần liên hệ bộ phận hỗ trợ và cung cấp các thông tin cần thiết như mã đặt vé, thời gian giao dịch và thông tin tài khoản để được xử lý nhanh hơn."
                           TextWrapping="Wrap" Foreground="#495057" Margin="0,0,0,40" LineHeight="20"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid Margin="32,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="⚠ Vui lòng kéo xuống cuối để xem toàn bộ chính sách"
                           Foreground="#666"
                           FontSize="12"
                           Margin="0,0,0,12"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScrolledToBottom}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Row="1" Content="Đồng ý"
                        Style="{StaticResource AgreeButtonStyle}"
                        IsEnabled="{Binding IsAgreeButtonEnabled}"
                        Command="{Binding AgreeCommand}"
                        Click="AgreeButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
